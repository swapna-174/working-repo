
CREATE OR REPLACE TABLE  stage.rdsc.rdsc_epic_clinicalresearch_rbr_reviews AS 
WITH CTE_HB AS

(
SELECT DISTINCT
    HARMAP.INTERNAL_ID
  , HBRSH.HSP_ACCOUNT_ID
  , RSH.RESEARCH_ID AS EPIC_STUDY_ID
  , RSH.STUDY_CODE AS STUDY_CODE
  , RSH.IRB_APPROVAL_NUM
  , RSH.RESEARCH_NAME AS STUDY_NAME
  , trim(right (RSH.RESEARCH_NAME,charindex('-',reverse(RSH.RESEARCH_NAME))-1)) as STUDY_DEPARTMENT
  , NULL AS DATE_OF_SERVICE
  , HPT.pat_mrn as PATIENT_MRN
  , PT.pat_name AS PATIENT_NAME
  , EMP.NAME AS REVIEWER_NAME
  , HBRSH.RSH_REV_TYPE_C As Review_Tier
  , HBRSH.LINE AS REVIEW_NUM
  , CAST(HBRSH.RSH_REV_QLFY_LOC_DTTM AS TIMESTAMP) AS REVIEW_QUALIFY_DATE
  , CAST(HBRSH.RSH_REV_DTTM AS TIMESTAMP) AS REVIEW_DATE
  , CAST(HBRSH.RSH_REV_EXPIRE_LOC_DTTM AS TIMESTAMP) AS REVIEW_EXPIRE_DATE
  , 'HB' AS BILLINGSYSTEMTYPE

FROM CLARITY.HSP_RSH_CHGREV_QLFY_HX AS HBRSH
  INNER JOIN CLARITY.HAR_MAP AS HARMAP ON HBRSH.HSP_ACCOUNT_ID = HARMAP.CID
  LEFT JOIN CLARITY.CLARITY_EMP AS EMP ON HBRSH.RSH_REV_USER_ID = EMP.USER_ID
  INNER JOIN CLARITY.CLARITY_RSH AS RSH ON HBRSH.REV_RESEARCH_ID = RSH.RESEARCH_ID
  INNER JOIN CLARITY.HSP_ACCT_PAT_MRN AS HPT ON HBRSH.HSP_ACCOUNT_ID = HPT.HSP_ACCOUNT_ID
  INNER JOIN CLARITY.PATIENT AS PT ON HPT.pat_mrn = PT.pat_mrn_id
)
,


CTE_PB AS

(
SELECT DISTINCT
    HARMAP.INTERNAL_ID
  , TXMOD.HOSP_ACCT_ID AS HSP_ACCOUNT_ID
  , RSH.RESEARCH_ID AS EPIC_STUDY_ID
  , RSH.STUDY_CODE AS STUDY_CODE
  , RSH.IRB_APPROVAL_NUM
  , RSH.RESEARCH_NAME AS STUDY_NAME
  , trim(right (RSH.RESEARCH_NAME,charindex('-',reverse(RSH.RESEARCH_NAME))-1)) as STUDY_DEPARTMENT
  , CAST(TDL.ORIG_SERVICE_DATE AS TIMESTAMP) AS DATE_OF_SERVICE
  , HPT.pat_mrn as PATIENT_MRN
  , PT.pat_name AS PATIENT_NAME
  , EMP.NAME AS REVIEWER_NAME
  , PBRSH.RSH_REV_TYPE_C As Review_Tier
  , PBRSH.LINE AS REVIEW_NUM
  , CAST(PBRSH.RSH_REV_QLFY_LOC_DTTM AS TIMESTAMP) AS REVIEW_QUALIFY_DATE
  , CAST(PBRSH.RSH_REV_DTTM AS TIMESTAMP) AS REVIEW_DATE
  , CAST(PBRSH.RSH_REV_EXPIRE_LOC_DTTM AS TIMESTAMP) AS REVIEW_EXPIRE_DATE
  , 'PB' AS BILLINGSYSTEMTYPE

FROM CLARITY.ARPB_RSH_CHGREV_QLFY_HX AS PBRSH
  INNER JOIN CLARITY.ARPB_TX_MODERATE AS TXMOD ON PBRSH.TX_ID = TXMOD.TX_ID
  INNER JOIN CLARITY.HAR_MAP AS HARMAP ON TXMOD.HOSP_ACCT_ID = HARMAP.CID
  LEFT JOIN CLARITY.CLARITY_EMP AS EMP ON PBRSH.RSH_REV_USER_ID = EMP.USER_ID
  INNER JOIN CLARITY.CLARITY_RSH AS RSH ON PBRSH.REV_RESEARCH_ID = RSH.RESEARCH_ID
  INNER JOIN CLARITY.HSP_ACCT_PAT_MRN AS HPT ON TXMOD.HOSP_ACCT_ID = HPT.HSP_ACCOUNT_ID
  INNER JOIN CLARITY.PATIENT AS PT ON HPT.pat_mrn = PT.pat_mrn_id
  INNER JOIN CLARITY.CLARITY_TDL AS TDL ON TXMOD.TX_ID = TDL.TX_ID
)


SELECT hb.*, CASE 
    WHEN Review_Qualify_Date <= '2025-11-05' AND Review_Tier = 1 THEN 1
    WHEN Review_Qualify_Date >  '2025-11-05' AND Review_Tier = 2 THEN 1
    ELSE 0
END AS RBR_Flag,
Sysdate() as Data_As_Of
 FROM CTE_HB hb

UNION

SELECT pb.*, CASE 
    WHEN Review_Qualify_Date <= '2025-11-05' AND Review_Tier = 1 THEN 1
    WHEN Review_Qualify_Date >  '2025-11-05' AND Review_Tier = 2 THEN 1
    ELSE 0
END AS RBR_Flag , Sysdate() as Data_As_Of
FROM CTE_PB pb
