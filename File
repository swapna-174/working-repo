
SELECT
    pat.primarymrn,
    MAX(CASE
            WHEN ord.QuestionName = 'AH ONCBCN INITIATE TX PLAN- TXT DEPARTMENT (IP/INF CENTER)'
            THEN ord.QuestionResponse
        END) AS department,
    MAX(CASE
            WHEN ord.QuestionName = 'AH ONCBCN INITIATE PLAN- PROBLEMS'
            THEN ord.QuestionResponse
        END) AS typeOfCancer,
    MAX(CASE
            WHEN ord.QuestionName = 'AH ONCBCN INITIATE PLAN- TREATMENT GOAL'
            THEN ord.QuestionResponse
        END) AS treatmentGoal
FROM caboodle.ProcedureOrderFact pof
LEFT JOIN caboodle.OrderQuestionAnswerMappingFactX ord
    ON ord.ProcedureOrderKey = pof.ProcedureOrderKey
LEFT JOIN caboodle.ProcedureDim p
    ON pof.ProcedureDurableKey = p.DurableKey
    LEFT JOIN caboodle.Patientdim pat
    ON pof.PatientDurableKey = pat.DurableKey
WHERE
   p.NAME = 'ONCOLOGY PLAN OP INITIATION ORDER (CDF-S & GORDON)'
